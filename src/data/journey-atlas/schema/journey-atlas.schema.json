{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tobogganlabs.ai/schemas/journey-atlas.schema.json",
  "title": "Journey Atlas",
  "type": "object",
  "required": ["meta", "stages", "handoffs", "lanes", "items", "kpis"],
  "properties": {
    "meta": {
      "type": "object",
      "required": [
        "id",
        "title",
        "subtitle",
        "version",
        "synthesisAsOf",
        "frozenAt",
        "sourceDoc"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "subtitle": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "synthesisAsOf": { "type": "string", "format": "date" },
        "frozenAt": { "type": "string", "format": "date" },
        "sourceDoc": { "type": "string", "minLength": 1 }
      },
      "additionalProperties": false
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "num", "name", "order"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "num": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "order": { "type": "integer", "minimum": 1 },
          "meta": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "handoffs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "order", "evidenceCount", "lifecycleStageId"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "order": { "type": "integer", "minimum": 1 },
          "evidenceCount": { "type": "integer", "minimum": 0 },
          "lifecycleStageId": { "type": "string", "minLength": 1 },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "lanes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "order"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "order": { "type": "integer", "minimum": 1 },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "laneId", "handoffIds", "tag", "text", "evidence"],
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "laneId": { "type": "string", "minLength": 1 },
          "handoffIds": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "tag": { "type": "string", "minLength": 1 },
          "text": { "type": "string", "minLength": 1 },
          "severity": { "type": "string", "enum": ["low", "med", "high"] },
          "impact": { "type": "string", "enum": ["low", "med", "high"] },
          "status": { "type": "string", "enum": ["planned", "active", "shipped"] },
          "tier": { "type": ["string", "null"], "enum": ["tier-1", "tier-2", "tier-3", null] },
          "developmentSubTrack": {
            "type": "string",
            "enum": ["design", "dev", "data-ai", "infra"]
          },
          "archetypes": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "notionPageId": { "type": ["string", "null"] },
          "evidence": {
            "type": "object",
            "required": ["mentionCount", "sourceSections"],
            "properties": {
              "mentionCount": { "type": "integer", "minimum": 0 },
              "interviews": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "projects": {
                "type": "array",
                "items": { "type": "string", "minLength": 1 }
              },
              "sourceSections": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string", "minLength": 1 }
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "kpis": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "handoffId",
          "qualLabel",
          "qualValue",
          "quantLabel",
          "quantValue",
          "health"
        ],
        "properties": {
          "handoffId": { "type": "string", "minLength": 1 },
          "qualLabel": { "type": "string", "minLength": 1 },
          "qualValue": { "type": "string", "minLength": 1 },
          "quantLabel": { "type": "string", "minLength": 1 },
          "quantValue": { "type": "string", "minLength": 1 },
          "health": { "type": "string", "enum": ["good", "warn", "bad"] },
          "detailBullets": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "spark": {
            "type": "array",
            "items": { "type": "number" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
